---
import { PRELOADER } from "../../utils/config";
---

<div id="loader">
  <div class="loading-left-bg loading-bg"></div>
  <div class="loading-right-bg loading-bg"></div>
  <div class="spinner-box">
    <div class="loading-taichi rotate">
      <img src="/images/cup.png" width="100" height="100" alt="loading" />
    </div>
    <div class="loading-word" id="loading-text"></div>
  </div>
</div>

<script is:inline>
  // 打字机效果：♪～♪～K-ON!
  const text = "♪～♪～K-ON!";
  const speeds = [50, 50, 50, 50, 80, 400, 80, 80, 80];
  var charIndex = 0;
  var el = document.getElementById("loading-text");

  function typeChar() {
    if (charIndex < text.length) {
      el.textContent += text[charIndex];
      var delay = speeds[charIndex];
      charIndex++;
      setTimeout(typeChar, delay);
    }
  }
  typeChar();

  var time = null;
  var endLoading = () => {
    if (!time) {
      document.body.style.overflow = "auto";
      document.getElementById("loader").classList.add("loading");
    } else {
      if (Date.now() - time > 500) {
        time = null;
        document.body.style.overflow = "auto";
        document.getElementById("loader").classList.add("loading");
      } else {
        setTimeout(endLoading, 500 - (Date.now() - time));
        time = null;
      }
    }
  };
  window.addEventListener("DOMContentLoaded", endLoading);
  document.addEventListener("astro:page-load", endLoading);
  document.getElementById("loader").addEventListener("click", endLoading);
</script>

<style lang="stylus">
:global([data-theme="dark"])
  #loader 
    .loading-bg
      background-color: rgba(37, 37, 37, .9)

    .spinner-box .loading-word
      color: var(--accent-1, #ff5252)

#loader
  .loading-bg
    position: fixed
    z-index: 1000
    width: 50%
    height: 100%
    background-color: rgba(255, 255, 255, .9)
    transition: .8s

  .loading-right-bg
    right: 0

  .spinner-box
    position: fixed
    z-index: 1001
    display: flex
    justify-content: center
    align-items: center
    width: 100%
    height: 100vh
    opacity: 1
    transition: .5s

    .loading-taichi
      opacity: .8
      
    .rotate
      animation: rotate-all 2s linear infinite

    .loading-word
      position: absolute
      color: var(--accent-1, #ff5252)
      top: calc(50% + 110px)
      left: 50%
      transform: translate(-50%, -50%)
      font: 700 1.2rem 'LXGW WenKai Screen', -apple-system, PingFang SC,
      Microsoft YaHei, sans-serif;

#loader.loading 
  .loading-left-bg
	  transform: translate(-100%, 0)

  .loading-right-bg
	  transform: translate(100%, 0)

#loader.loading 
  .spinner-box
    opacity: 0
    visibility: hidden

@keyframes rotate-all
  100%
    transform: rotate(360deg)
</style>
