---
import type { HTMLAttributes } from "astro/types";
import { Icon } from "astro-icon/components";
import { MENU } from "../../utils/config";
import { __ } from "../../utils/i18n";

type Props = HTMLAttributes<"a"> & { name?: string };

const { href, name, ...props } = Astro.props;
// each menu item gets a different tea cup icon
const icons = ["mug-hot", "mug-saucer", "martini-glass"];
const iconIndex = MENU.findIndex(m => m.url === href);
const iconName = icons[iconIndex >= 0 && iconIndex < icons.length ? iconIndex : 0];
---

<span class="main-nav-link-wrap">
  <Icon name={"fa6-solid:" + iconName} class="main-nav-icon" size={24} />
  <a class="main-nav-link" href={href} {...props}><slot /></a>
</span>

<style lang="stylus">
  .main-nav-link-wrap {
    color: var(--accent-0);
    opacity: 0.8;
    text-decoration: none;
    padding: 0 15px;
    display: flex;
    transition: .3s;

    @media screen and (max-width: 959px) {
      padding: 0 10px;
    }

    @media screen and (max-width: 767px) {
      display: none;
    }

    &:hover {
      opacity: 1;
    }
    &:hover .main-nav-icon {
      transform: scale(1.1);
    }
  }

  .main-nav-link {
    color: var(--accent-0);
    opacity: 0.7;
    text-decoration: none;
    transition: opacity 0.2s;
    padding: 20px 15px;
    letter-spacing: 1px;
    font-weight: 700;
  }

  :global([data-theme='dark']) {
    .main-nav-link, .main-nav-link-wrap {
      color: var(--accent-2);
    }
  }

  .main-nav-icon {
    opacity: 0.8;
    color: var(--accent-0);
    text-decoration: none;
    display: block;
    padding: 15px 5px;
    display: flex;
    align-items: center;
    font-size: 24px;
    font-weight: 400;
    transform: scale(1);
    transition: transform 0.3s, color 0.3s;
    cursor: pointer;
    will-change: transform;
  }
</style>
