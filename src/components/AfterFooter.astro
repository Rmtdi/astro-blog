---

<!-- busuanzi -->
{
  FOOTER.busuanzi && 
  <script>
  document.addEventListener('astro:page-load', () => {
    window.loadScript("https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js", "busuanzi-script");
  })
</script>
}

<!-- aos -->
<script>
  import AOS from "@reimujs/aos";
  const aosInit = () => {
    AOS.init({
      duration: 1000,
      easing: "ease",
      once: true,
      offset: 50,
    });
  };
  aosInit();
  document.addEventListener("astro:after-swap", aosInit);
</script>
<!-- ThemeToogle -->
<script>
  // prevent flash when using view transitions in astro
  const initColorMode = () => {
    const storedTheme = JSON.parse(
      window.localStorage.getItem("theme") ?? '"auto"'
    );
    let presetTheme;
    if (storedTheme === "auto") {
      presetTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
    } else {
      presetTheme = storedTheme;
    }
    if (presetTheme === "dark") {
      document.documentElement.setAttribute("data-theme", "dark");
      document.documentElement.style.colorScheme = "dark";
    } else {
      document.documentElement.removeAttribute("data-theme");
      document.documentElement.style.colorScheme = "light";
    }
  };

  // Runs on initial navigation
  initColorMode();
  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", initColorMode);
</script>
<!-- Note burst -->
<script>
  document.addEventListener('astro:page-load', () => {
    document.addEventListener('click', (e) => {
      if (e.target.closest('a, button, .nav-icon, #main-nav-toggle')) return;

      var notes = ['♪', '♫', '♩', '♬'];
      var colors = [
        'hsla(348,78%,72%,1)','hsla(348,62%,78%,1)','hsla(260,58%,74%,1)',
        'hsla(215,68%,70%,1)','hsla(170,58%,70%,1)','hsla(25,75%,72%,1)',
        'hsla(45,68%,74%,1)','hsla(330,55%,76%,1)',
      ];
      var cx = e.clientX, cy = e.clientY;

      // 圆环 linear 淡出 0.5s
      var ringMax = 70;
      var ringStart = performance.now();
      var ring = document.createElement('div');
      ring.style.cssText = 'position:fixed;pointer-events:none;z-index:99998;border-radius:50%;' +
        'border:2px solid hsla(170,50%,65%,0.85);left:' + cx + 'px;top:' + cy + 'px;width:0;height:0;opacity:1;';
      document.body.appendChild(ring);
      (function animRing() {
        var t = Math.min((performance.now() - ringStart) / 400, 1);
        var r = ringMax * t;
        ring.style.left = (cx - r) + 'px'; ring.style.top = (cy - r) + 'px';
        ring.style.width = (r * 2) + 'px'; ring.style.height = (r * 2) + 'px';
        ring.style.opacity = 1 - t;
        if (t < 1) requestAnimationFrame(animRing);
        else ring.remove();
      })();

      // 粒子：一开始大然后快速变小 + 飞散
      var count = 10, maxRadius = 95;
      for (var i = 0; i < count; i++) {
        var ang = Math.random() * Math.PI * 2 + (Math.random()-0.5)*0.3;
        var spd = 120 + Math.random() * 120;
        var g = 40 + Math.random() * 40;
        var note = notes[i % notes.length];
        var el = document.createElement('span');
        el.textContent = note;
        // 初始 38px，每个粒子起始位置 jitter 进一步分散
        var jitter = 30;
        el.style.cssText = 'position:fixed;pointer-events:none;z-index:99999;' +
          'font-size:38px;font-weight:bold;' +
          'color:' + colors[i % colors.length] + ';' +
          'left:' + (cx - 19 + (Math.random()-0.5)*jitter) + 'px;' +
          'top:' + (cy - 19 + (Math.random()-0.5)*jitter) + 'px;opacity:1;';
        document.body.appendChild(el);

        var vx = Math.cos(ang) * spd;
        var vy = Math.sin(ang) * spd - 40;
        var born = performance.now();
        var ox = cx + (Math.random()-0.5)*30;
        var oy = cy + (Math.random()-0.5)*30;

        (function(el, ox, oy, vx, vy, g, born) {
          (function anim(now) {
            var dt = (now - born) / 1000;
            if (dt > 0.7) { el.remove(); return; }
            var t = Math.min(dt / 0.7, 1);
            var x = ox + vx * dt;
            var y = oy + vy * dt + 0.5 * g * dt * dt;
            if (Math.sqrt((x-ox)*(x-ox)+(y-oy)*(y-oy)) > maxRadius) { el.remove(); return; }
            // 先慢后快：ease-out 二次方，从 34px 缩到 6px
            var shrink = 1 - Math.pow(1 - t, 1.5);
            var curSize = 38 - 24 * shrink;
            el.style.fontSize = curSize + 'px';
            el.style.left = (x - curSize / 2) + 'px';
            el.style.top = (y - curSize / 2) + 'px';
            el.style.opacity = Math.pow(1 - t, 0.5);
            requestAnimationFrame(anim);
          })(born);
        })(el, ox, oy, vx, vy, g, born);
      }
    });
  });
</script>

<!-- Copyright -->
<script is:inline define:vars={{ copyright, version: packageData.version }}>
  console.log(String.raw`%c ${copyright}`,'color: #7d9b4e;')
  console.log('%c Theme.Reimu v' + `${version}` + ' %c https://github.com/D-Sketon/astro-theme-reimu ', 'color: white; background: #7d9b4e; padding:5px 0;', 'padding:4px;border:1px solid #7d9b4e;')
</script>